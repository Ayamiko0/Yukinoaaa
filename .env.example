# ==============================================================================
# YUKINOAAA TRADING ASSISTANT - ENVIRONMENT CONFIGURATION (EXAMPLE)
# ==============================================================================
# Sao chép file này thành .env và điền các giá trị thực tế của bạn:
#   cp .env.example .env
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. APPLICATION & SERVER SETTINGS
# ------------------------------------------------------------------------------
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO
YUKINOAAA_HOST=0.0.0.0
YUKINOAAA_PORT=8000

# ------------------------------------------------------------------------------
# 2. DOCKER & DATABASE CONFIGURATION
# ------------------------------------------------------------------------------
# Khi chạy với Docker Compose, sử dụng tên service làm host (postgres, redis)
# Khi chạy local không qua Docker, đổi host thành localhost hoặc 127.0.0.1
DATABASE_URL=postgresql+asyncpg://yukinoaaa:secret_password@postgres:5432/yukinoaaa_db
REDIS_URL=redis://default:secret_redis@redis:6379/0

# Thông tin đăng nhập cho Docker containers (PostgreSQL & Redis)
POSTGRES_USER=yukinoaaa
POSTGRES_PASSWORD=secret_password
POSTGRES_DB=yukinoaaa_db
REDIS_PASSWORD=secret_redis

# ------------------------------------------------------------------------------
# 3. DISCORD INTEGRATION & BOT GATEWAY
# ------------------------------------------------------------------------------
# Kích hoạt hoặc vô hiệu hóa tính năng thông báo và Slash Command qua Discord
DISCORD_ENABLED=true

# Webhook URL để nhận thông báo tự động (OrderFilled, SignalCreated, v.v.)
# Lấy từ Discord Server -> Channel Settings -> Integrations -> Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Bot Token dùng cho xác thực API của Discord Bot
# Lấy từ Discord Developer Portal -> Application -> Bot -> Reset Token
DISCORD_BOT_TOKEN=YOUR_DISCORD_BOT_TOKEN_HERE

# Public Key dùng để xác thực chữ ký Ed25519 từ Discord HTTP Interactions Gateway
# Lấy từ Discord Developer Portal -> Application -> General Information -> Public Key
DISCORD_PUBLIC_KEY=YOUR_DISCORD_PUBLIC_KEY_HERE

# Application ID (Client ID) của Discord Bot dùng để đăng ký Slash Commands
# Lấy từ Discord Developer Portal -> Application -> General Information -> Application ID
DISCORD_APPLICATION_ID=YOUR_DISCORD_APPLICATION_ID_HERE

# ------------------------------------------------------------------------------
# 4. OLLAMA LOCAL LLM AI INTEGRATION
# ------------------------------------------------------------------------------
# Kích hoạt hoặc vô hiệu hóa tính năng phân tích định lượng bằng Local LLM qua Ollama
OLLAMA_ENABLED=true

# REST API Base URL của Ollama
# - Chạy trên Host local: http://localhost:11434/api
# - Chạy trong Docker container (Linux / macOS / Windows): http://host.docker.internal:11434/api
#   (Lưu ý: Khi chạy Ollama trên Host Linux, cần export OLLAMA_HOST=0.0.0.0 để container kết nối được)
OLLAMA_BASE_URL=http://host.docker.internal:11434/api

# Tên mô hình LLM chạy trên Ollama (ví dụ: gemma3, llama3, qwen2.5)
OLLAMA_MODEL=gemma3:1b

# Số token ngữ cảnh tối đa và token đầu ra
OLLAMA_NUM_CTX=4096
OLLAMA_NUM_PREDICT=512
OLLAMA_TEMPERATURE=0.2
OLLAMA_TIMEOUT_SEC=30.0
